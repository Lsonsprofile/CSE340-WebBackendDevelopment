<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <ul class="project-list">
        <% projects.forEach(project => { %>
            <li class="project-items">
                <strong>
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>
                </strong>

                Sponsored By
                <a href="/organization/<%= project.organization_id %>">
                    <%= project.organization_name %>
                </a>
                Coming Up

                <%= new Date(project.project_date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                }) %>
            </li>
        <% }) %>
    </ul>
</main>

<%- include('partials/footer') %>